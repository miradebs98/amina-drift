# Copy to .env (git-ignored) and fill in. Most Layer-1 sources are free/no-auth.

# --- LLM (drift engine: verdict + explain) — Apertus on CSCS (Swiss-sovereign, no OpenAI) ---
# The drift engine reads THESE vars (backend/drift/llm.py::get_llm). OpenAI-compatible endpoint.
DRIFT_LLM_BASE_URL=https://api.swissai.svc.cscs.ch/v1
DRIFT_LLM_API_KEY=            # sk-rc-… key from the Swiss AI Research Platform — ask the team (git-ignored, NEVER commit)
DRIFT_LLM_CHEAP_MODEL=swiss-ai/Apertus-8B-Instruct-2509     # Stage-2 verdict (high volume)
DRIFT_LLM_HEAVY_MODEL=swiss-ai/Apertus-70B-Instruct-2509    # Stage-3 deep-dive / explanation
# Sovereign embeddings for Stage-1 relevance (optional; default = lexical/free):
# RELEVANCE_EMBEDDINGS=swissai
# SWISSAI_EMBED_MODEL=Snowflake/snowflake-arctic-embed-l-v2.0   # 1024-d, Swiss-hosted on the same key

# --- grain_lite (SEC filings + earnings calls) ---
# OPENAI is OPTIONAL now — the verdict + embeddings run on Apertus (above). Only needed if you
# deliberately use grain_lite's OpenAI embedder/verdict instead of the sovereign path.
OPENAI_API_KEY=              # optional (superseded by DRIFT_LLM_* + RELEVANCE_EMBEDDINGS=swissai)
ALPHAVANTAGE_API_KEY=        # free tier — earnings-call transcripts (grain_lite/sources/transcript.py)
SEC_USER_AGENT=amina-drift (you@email.com)   # SEC EDGAR requires a UA string
# optional grain_lite overrides (sensible defaults in backend/grain_lite/config.py):
# GRAIN_LLM_MODEL=gpt-4.1-mini
# GRAIN_EMBEDDING_MODEL=text-embedding-3-small
# GRAIN_CACHE_DIR=.grain_cache

# --- Layer 1 sources (most are keyless) ---
# GDELT, Google News RSS, GLEIF, ZEFIX, Wayback CDX: no key needed.
NEWSAPI_KEY=                 # optional (newsapi.org / Event Registry partner MCP)
OPENCORPORATES_KEY=          # optional; GLEIF/ZEFIX cover most needs keyless
OPENSANCTIONS_API_KEY=       # optional; self-host yente or use free non-commercial API

# --- runtime ---
DATABASE_URL=sqlite:///./amina_drift.sqlite
OFFLINE_DEMO=true            # serve from data/fixtures/ so the stage demo needs no network
