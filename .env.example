# amina-drift local secrets — git-ignored, never committed.
# Fill in values after the "=" (no quotes). Restart any running process after editing.

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  👉 PASTE YOUR APERTUS / CSCS KEY HERE  (the only key still missing)       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Powers BOTH: the LLM cascade (verdict/scoring) AND the free swissai embeddings.
# From the hackathon Apertus/CSCS onboarding — OpenAI-compatible /chat/completions.
DRIFT_LLM_BASE_URL=https://api.swissai.svc.cscs.ch/v1
DRIFT_LLM_API_KEY=
DRIFT_LLM_CHEAP_MODEL=swiss-ai/Apertus-8B-Instruct-2509     # exact CSCS model id
DRIFT_LLM_HEAVY_MODEL=swiss-ai/Apertus-70B-Instruct-2509

# ── Already set (the keys you added) ──────────────────────────────────────────
EVENTREGISTRY_API_KEY=      # news + sentiment
OPENSANCTIONS_API_KEY=      # sanctions/PEP screening

# ── SEC EDGAR (no key — just needs a contact string) ──────────────────────────
SEC_USER_AGENT=amina-drift (team@sablier.it)

# ── Runtime toggles ───────────────────────────────────────────────────────────
OFFLINE_DEMO=true            # true = replay fixtures (no network/keys); false = hit live sources
SEC_LEVEL2=false             # true = read 10-K full text → cited passages
RELEVANCE_EMBEDDINGS=lexical # lexical (free) | swissai (free, needs Apertus key) | local | openai (paid)

# ── Optional ──────────────────────────────────────────────────────────────────
# ALPHAVANTAGE_API_KEY=      # free key → enables earnings-call transcripts
# YENTE_BASE_URL=http://localhost:8000   # self-hosted yente (free, keyless) instead of OpenSanctions key
